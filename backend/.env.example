PORT=3000

# Supabase PostgreSQL connection string
# Found in: Supabase dashboard → Project Settings → Database → Connection string (URI)
# Use port 6543 for transaction/pooler mode, 5432 for session mode
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# JWT
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=8h

# Google OAuth
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials
# Add http://localhost:3000/api/auth/google/callback to "Authorized redirect URIs"
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Frontend URL (used to redirect after OAuth callback)
FRONTEND_URL=http://localhost:5173
