PORT=3000

# PostgreSQL local (Docker Compose)
# When running via docker-compose, the host is "postgres" (service name)
# When running the backend directly without Docker, use "localhost"
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/kontrol

# Set to "true" only if connecting to a remote DB that requires SSL (e.g. Supabase)
DATABASE_SSL=false

# JWT
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=8h

# Google OAuth
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials
# Add http://localhost:3000/api/auth/google/callback to "Authorized redirect URIs"
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Frontend URL (used to redirect after OAuth callback)
FRONTEND_URL=http://localhost:5173
